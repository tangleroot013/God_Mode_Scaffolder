import pytest
from utils.fs_helper import atomic_scaffold

def test_scaffold_is_rolled_back_on_error(tmp_path: pathlib.Path) -> None:
    """Verifies that failures during generation do not pollute the destination path."""
    target_dir = tmp_path / "new_project"
    
    def failing_generator(temp_root: pathlib.Path) -> None:
        (temp_root / "scaffolding_file.txt").write_text("Hello World", encoding="utf-8")
        raise RuntimeError("Simulated writing error!")
        
    with pytest.raises(RuntimeError):
        atomic_scaffold(target_dir, failing_generator)
        
